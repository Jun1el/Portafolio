@model IEnumerable<Portafolio.Models.Proyecto>
@if (Model != null)
{
	<div class="container container-fluid border-0">
		<div class="row justify-content-center text-center mt-3 mb-3 text-white">
			<div class="col">
				<h3>Mis Proyectos Recientes</h3>
				<div class="row mt-4">
					@foreach (var proyecto in Model)
					{
						<div class="col-md-4 mb-4">
							<div class="card h-100 bg-transparent border-light text-white box-shadow">
								<img src="@proyecto.ImgURL" class="card-img-top" alt="@proyecto.Titulo" style="height: 200px; object-fit: cover;" />
								<div class="card-body d-flex flex-column">
									<h5 class="card-title text-white">@proyecto.Titulo</h5>
									<p class="card-text">@proyecto.Descripcion</p>
									<a href="@proyecto.Link" class="btn btn-outline-light mt-auto" target="_blank" rel="noreferrer noopener">Ver Proyecto</a>
								</div>
							</div>
						</div>
					}
				</div>
			</div>
		</div>
	</div>
}