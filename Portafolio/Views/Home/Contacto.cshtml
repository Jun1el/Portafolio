@{
	ViewData["Title"] = "Contacto";
}

<section class="contacto-section">
	<div class="container">
		<div class="contacto-grid">
			<div class="contacto-card">
				<div class="contacto-header">
					<h1 class="contacto-header__title">Hablemos</h1>
					<p class="contacto-header__subtitle">¿Tienes un proyecto en mente o quieres colaborar? Envíame un mensaje y te responderé lo antes posible.</p>
					<div class="contacto-header__divider"></div>
				</div>

				<form asp-controller="Home" asp-action="Contacto" class="contacto-form" id="contacto-form">
					<input type="hidden" name="_captcha" value="false">

					<div class="form-group">
						<label for="Nombre" class="form-label">Nombre</label>
						<input type="text" id="Nombre" name="Nombre" class="form-control" placeholder="Tu nombre completo" required>
					</div>

					<div class="form-group">
						<label for="email" class="form-label">Correo Electrónico</label>
						<input type="email" id="email" name="email" class="form-control" placeholder="tu-email@ejemplo.com" required>
					</div>

					<div class="form-group">
						<label for="Numero" class="form-label">Teléfono</label>
						<input type="tel" id="Numero" name="Numero" class="form-control" placeholder="Tu número de teléfono" inputmode="numeric" pattern="[0-9]*" minlength="9" maxlength="12" required>
					</div>

					<div class="form-group">
						<label for="Mensaje" class="form-label">Mensaje</label>
						<textarea id="message" name="Mensaje" class="form-control" placeholder="Cuéntame sobre tu proyecto o idea..." required></textarea>
					</div>

					<div class="form-actions">
						<button type="submit" class="btn-premium">Enviar Mensaje</button>
						<a asp-controller="Home" asp-action="Index" class="btn-cancel">Cancelar</a>
					</div>
				</form>
			</div>

			<aside class="contacto-info">
				<div class="contacto-info__header">
					<h2 class="contacto-info__title">Información de Contacto</h2>
					<p class="contacto-info__text">También puedes contactarme directamente a través de estos canales.</p>
				</div>

